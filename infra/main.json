{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "5124729159857811099"
    }
  },
  "parameters": {
    "namePrefix": {
      "type": "string",
      "defaultValue": "[toLower(replace(resourceGroup().name, '_', '-'))]",
      "metadata": {
        "description": "Base name for all resources (letters/numbers/hyphen)."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for resources."
      }
    },
    "appServicePlanSku": {
      "type": "string",
      "defaultValue": "B1",
      "metadata": {
        "description": "App Service Plan SKU name (e.g. B1, P1v3)."
      }
    },
    "webAppName": {
      "type": "string",
      "defaultValue": "[format('{0}-web-{1}', parameters('namePrefix'), uniqueString(resourceGroup().id))]",
      "metadata": {
        "description": "Unique web app name for Node service."
      }
    },
    "pyApiAppName": {
      "type": "string",
      "defaultValue": "[format('{0}-pyapi-{1}', parameters('namePrefix'), uniqueString(resourceGroup().id))]",
      "metadata": {
        "description": "Unique web app name for Python API service."
      }
    },
    "openAiBaseUrl": {
      "type": "string",
      "defaultValue": "https://api.openai.com/v1",
      "metadata": {
        "description": "OpenAI-compatible base URL (e.g. https://api.openai.com/v1)."
      }
    },
    "openAiApiKey": {
      "type": "securestring",
      "metadata": {
        "description": "OpenAI API key (set via azd env set or during deployment)."
      }
    },
    "openAiModel": {
      "type": "string",
      "metadata": {
        "description": "OpenAI model name (e.g. gpt-4o-mini)."
      }
    }
  },
  "variables": {
    "planName": "[format('{0}-plan', parameters('namePrefix'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[variables('planName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('appServicePlanSku')]",
        "tier": "[if(equals(parameters('appServicePlanSku'), 'F1'), 'Free', if(equals(parameters('appServicePlanSku'), 'B1'), 'Basic', 'PremiumV3'))]"
      },
      "kind": "linux",
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[parameters('webAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "NODE|20-lts",
          "appSettings": [
            {
              "name": "WEBSITE_NODE_DEFAULT_VERSION",
              "value": "~20"
            },
            {
              "name": "SCM_DO_BUILD_DURING_DEPLOYMENT",
              "value": "true"
            },
            {
              "name": "OPENAI_BASE_URL",
              "value": "[parameters('openAiBaseUrl')]"
            },
            {
              "name": "OPENAI_API_KEY",
              "value": "[parameters('openAiApiKey')]"
            },
            {
              "name": "OPENAI_MODEL",
              "value": "[parameters('openAiModel')]"
            },
            {
              "name": "LOG_LEVEL",
              "value": "info"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[parameters('pyApiAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "PYTHON|3.11",
          "appCommandLine": "gunicorn -k uvicorn.workers.UvicornWorker -w 2 -b 0.0.0.0:8000 app:app",
          "appSettings": [
            {
              "name": "SCM_DO_BUILD_DURING_DEPLOYMENT",
              "value": "true"
            },
            {
              "name": "OPENAI_BASE_URL",
              "value": "[parameters('openAiBaseUrl')]"
            },
            {
              "name": "OPENAI_API_KEY",
              "value": "[parameters('openAiApiKey')]"
            },
            {
              "name": "OPENAI_MODEL",
              "value": "[parameters('openAiModel')]"
            },
            {
              "name": "OPENAI_TIMEOUT_S",
              "value": "60"
            },
            {
              "name": "PORT",
              "value": "8000"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]"
      ]
    }
  ],
  "outputs": {
    "webAppHostname": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', parameters('webAppName')), '2023-12-01').defaultHostName]"
    },
    "pyApiHostname": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', parameters('pyApiAppName')), '2023-12-01').defaultHostName]"
    }
  }
}